@model IEnumerable<InAndOut.Models.Expense> 

<div class="container-p3">
    <div class="row pt-3">
        <div class="col-6">
            <h2 class="text-primary">Expenses List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-primary">Create new Expense</a>
        </div>
    </div>
    @if (Model.Count() > 0)     
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>
                        Expense
                    </th> 
                    <th>
                        Amount
                    </th>
                    <th>
                       Expense Type
                    </th>
                    <th>
                        Changes
                    </th>
                </tr>
                
            </thead>
            <tbody>
                @foreach (var expense in Model)
                {
                    <tr>
                        <td width="25%">@expense.ExpenseName</td>
                        <td width="25%">@expense.Amount</td>
                        <td width="25%">@expense.ExpenseType.Name</td>
                        <td width="20%">
                            <div class="w-100 btn-group" role="group">
                                <a asp-action="Update" asp-route-id="@expense.Id" class="btn btn-primary mx-1">Update</a>
                                <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-danger mx-1">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    }
    else
    {
        <p>No items created yet</p>
    }

</div>
